{
	"$schema": "https://opencode.ai/config.json",
	"model": "llama.cpp/default",
	//"model": "opencode/deepseek-v4-flash-free",
	"lsp": true,
	"formatter": true,
	"default_agent": "plan",
	"provider": {
		"llama.cpp": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "llama-server (local)",
			"options": {
				"baseURL": "http://127.0.0.1:10600/v1"
			},
			"models": {
				"default": {
					"name": "default",
					"options": {
						"reasoningEffort": "low",
						"textVerbosity": "low"
					},
					"limit": {
						"context": 131072,
						"output": 32768
					}
				}
			}
		}
	},
	"agent": {
		"docs-writer": {
			"description": "Writes concise code documentation with examples",
			"mode": "subagent",
			"permission": {
				"bash": "deny"
			}
		},
		"code-reviewer": {
			"description": "Reviews code for best practices and potential issues",
			"mode": "subagent",
			"prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
			"permission": {
				"edit": "deny"
			}
		},
		"plan": {
			"permission": {
				"bash": {
					"*": "ask",
					"git *": "allow",
					"git commit*": "deny"
				},
				"edit": "deny",
				"write": "deny"
			}
		},
		"explore": {
			"disable": true
		},
		"general": {
			"disable": true
		}
	},
	"permission": {
		"bash": {
			"*": "allow",
			"find *-exec*": "deny",
			"git push*": "deny",
			"rm -rf*": "deny",
			"sudo *": "deny"
		},
		"external_directory": {
			"/**": "deny"
		},
		"read": {
			"/**": "deny"
		},
		"edit": {
			"/**": "deny"
		}
	},
	"instructions": ["~/.config/opencode/guidelines.md", "AGENTS.md"],
	"plugin": ["oh-my-opencode-slim@latest", "opencode-codebase-index@latest", "./plugins/scheduler/index.ts"]
}
